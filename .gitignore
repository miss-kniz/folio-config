```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Build outputs
dist/
build/
target/

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.coverage.*
.python-version

# Coverage reports
coverage/
htmlcov/

# Local configuration
.julia/
zig-cache/
.deps/
*.tar.gz
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo

# System files
.DS_Store
Thumbs.db
```